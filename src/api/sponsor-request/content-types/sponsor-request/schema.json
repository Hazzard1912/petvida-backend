{
  "kind": "collectionType",
  "collectionName": "sponsor_requests",
  "info": {
    "singularName": "sponsor-request",
    "pluralName": "sponsor-requests",
    "displayName": "Sponsor Request",
    "description": "Solicitudes de apadrinamiento"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "pet": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::pet.pet",
      "inversedBy": "sponsorRequests"
    },
    "sponsor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::sponsor.sponsor",
      "inversedBy": "sponsorRequests"
    },
    "monthlyAmount": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "status": {
      "type": "enumeration",
      "enum": ["pendiente", "activa", "cancelada"],
      "default": "pendiente"
    }
  }
}
