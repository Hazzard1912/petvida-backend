{
  "kind": "collectionType",
  "collectionName": "sponsors",
  "info": {
    "singularName": "sponsor",
    "pluralName": "sponsors",
    "displayName": "Sponsor",
    "description": "Personas interesadas en apadrinar"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "sponsorRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::sponsor-request.sponsor-request",
      "mappedBy": "sponsor"
    }
  }
}
