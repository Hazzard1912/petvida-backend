{
  "kind": "collectionType",
  "collectionName": "productos",
  "info": {
    "singularName": "producto",
    "pluralName": "productos",
    "displayName": "Producto",
    "description": "Productos solidarios del catalogo de la fundacion"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nombre",
      "required": true
    },
    "descripcion": {
      "type": "text",
      "required": true
    },
    "precio": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "imagen": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "destacado": {
      "type": "boolean",
      "default": false
    },
    "whatsappMensaje": {
      "type": "text"
    }
  }
}
