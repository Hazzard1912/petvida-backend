{
  "kind": "collectionType",
  "collectionName": "adopters",
  "info": {
    "singularName": "adopter",
    "pluralName": "adopters",
    "displayName": "Adopter",
    "description": "Personas interesadas en adoptar"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "neighborhood": {
      "type": "string",
      "required": true
    },
    "age": {
      "type": "integer",
      "required": true,
      "min": 18
    },
    "adoptionRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::adoption-request.adoption-request",
      "mappedBy": "adopter"
    }
  }
}
